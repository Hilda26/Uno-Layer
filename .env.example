# UNO-LAYER Environment Variables
# Copy to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_NAME=UNO-LAYER

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://mgbsvlfopeazaypoxwow.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# GenLayer
# Contract: deployed at studio.genlayer.com
# RPC method: gen_call with type="read"|"write"|"deploy"
# Data format: "0x" + hex(JSON.stringify({ method, args }))
# Chain ID: 61999
NEXT_PUBLIC_GENLAYER_CONTRACT_ADDRESS=0xe9D921c7998197C27a6f79Bf16b6a9A8180a9016
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com/api
NEXT_PUBLIC_CHAIN_ID=61999
